    "@types/three": "^0.177.0",
    "@vitejs/plugin-react": "^4.3.4",
    "d3": "^7.9.0",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "three": "^0.177.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
