  "repository": {
    "type": "git",
    "url": "https://github.com/sidmanale643/Atlas"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "atlas": "./src/cli.js",
    "atlas-mcp": "./src/mcp-server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:web": "vite",
    "build:web": "vite build",
