{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build:web",
  "outputDirectory": "public/app",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://atlas-production-aa1e.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
